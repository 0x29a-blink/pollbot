DISCORD_TOKEN=your_token_here
DISCORD_CLIENT_ID=your_client_id_here

SUPABASE_URL=your_supabase_url_here
# service_role key for the backend (bypasses RLS). Keep secret.
SUPABASE_KEY=your_supabase_key_here

DEV_ONLY_MODE=true
DEV_GUILD_ID=your_dev_guild_id_here

# Runtime / hardening
# Set to "production" on the deployed host so the session cookie is Secure.
NODE_ENV=development
# Force the session cookie Secure flag on/off. Defaults to on when
# NODE_ENV=production. Leave unset (or false) for local HTTP testing.
# COOKIE_SECURE=true
# LOG_LEVEL=info
# RENDER_SERVICE_PORT=3000

TOPGG_TOKEN=your_topgg_token_here
TOPGG_WEBHOOK_AUTH=your_topgg_webhook_auth_here

# Cloudflare Tunnels
WEBHOOK_CLOUDFLARED_TOKEN=your_webhook_tunnel_token_here
MAIN_CLOUDFLARED_TOKEN=your_main_tunnel_token_here
# Optional third tunnel for the telemetry service; skipped when unset.
# TELEMETRY_TOKEN=your_telemetry_tunnel_token_here

# Dashboard OAuth (Discord)
DISCORD_CLIENT_SECRET=your_discord_client_secret_here
DISCORD_OAUTH_REDIRECT_URI=https://pollbot.win/api/auth/callback
DISCORD_ADMIN_IDS=123456789,987654321