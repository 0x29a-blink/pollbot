# Supabase project URL and anon (public) key — used for read-only stats and
# realtime subscriptions. Never put the service_role key here.
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Discord Client ID for bot invite links
VITE_DISCORD_CLIENT_ID=your_client_id_here

# API origin override. Leave unset to use the same origin the dashboard is
# served from (the bot serves both in production).
# VITE_API_URL=http://localhost:7500
